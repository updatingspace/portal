# Root env template for Portal stack.
# ID service is externalized and integrated either via local GHCR images
# or a deployed remote instance.

DJANGO_DEBUG=True
ALLOWED_HOSTS=.localhost,localhost,127.0.0.1,bff,access,portal,voting,events,gamification,activity,updspaceid
DJANGO_LOG_LEVEL=INFO

# Debug-only escape hatches for standalone local service runs.
# DJANGO_ALLOW_INSECURE_DEFAULTS=1
# DJANGO_ALLOW_SQLITE=1

# ID integration mode for scripts/dev-up.sh
# local  -> uses infra/docker-compose/docker-compose.dev.yml
# remote -> uses infra/docker-compose/docker-compose.remote.yml
ID_MODE=local

# Database runtime contract
DB_DRIVER=postgres
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/updspace_portal
# YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
# YDB_DATABASE=/ru-central1/b1gxxxxxxxxxxxxxxx/etnxxxxxxxxxxxxxxx
# YDB_NAME=default
# YDB_CREDENTIALS_MODE=metadata
# YDB_TOKEN=
# YDB_SERVICE_ACCOUNT_JSON=

# Internal trust (BFF -> services)
BFF_INTERNAL_HMAC_SECRET=dev-internal-hmac
BFF_UPDSPACEID_CALLBACK_SECRET=dev-callback-secret

# BFF tenant/dev settings
BFF_TENANT_HOST_SUFFIX=localhost
BFF_DEV_AUTO_TENANT=true
BFF_COOKIE_DOMAIN=.aef.localhost
ID_PUBLIC_BASE_URL=http://id.localhost

# Upstream URLs (BFF -> services)
ID_BASE_URL=http://updspaceid:8001/api/v1
BFF_UPSTREAM_ID_URL=http://updspaceid:8001/api/v1
ACCESS_BASE_URL=http://localhost:8002/api/v1
ACCESS_SERVICE_URL=http://localhost:8002
BFF_UPSTREAM_ACCESS_URL=http://localhost:8002/api/v1
BFF_UPSTREAM_PORTAL_URL=http://localhost:8003/api/v1
BFF_UPSTREAM_VOTING_URL=http://localhost:8004/api/v1
BFF_UPSTREAM_EVENTS_URL=http://localhost:8005/api/v1
BFF_UPSTREAM_FEED_URL=http://localhost:8006/api/v1
BFF_UPSTREAM_GAMIFICATION_URL=http://localhost:8007/api/v1
BFF_UPSTREAM_FEATUREFLAGS_URL=http://localhost:8008/api/v1
PORTAL_SERVICE_URL=http://localhost:8003/api/v1
ACTIVITY_SERVICE_URL=http://localhost:8006/api/v1

# YC private invoke URLs for BFF -> services
# BFF_UPSTREAM_ACCESS_INVOKE_URL=https://bba-access.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_PORTAL_INVOKE_URL=https://bba-portal.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_VOTING_INVOKE_URL=https://bba-voting.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_EVENTS_INVOKE_URL=https://bba-events.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_FEED_INVOKE_URL=https://bba-activity.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_GAMIFICATION_INVOKE_URL=https://bba-gamification.containers.yandexcloud.net/api/v1
# BFF_UPSTREAM_FEATUREFLAGS_INVOKE_URL=https://bba-featureflags.containers.yandexcloud.net/api/v1

# OIDC client for Portal in ID service (required in remote mode)
BFF_OIDC_CLIENT_ID=portal-dev-client
BFF_OIDC_CLIENT_SECRET=portal-dev-secret

# Privacy / retention
ACTIVITY_DATA_ENCRYPTION_KEY=dev-activity-encryption-key
PORTAL_RETENTION_AUDIT_DAYS=365
ACCESS_RETENTION_AUDIT_DAYS=365
ACTIVITY_RETENTION_AUDIT_DAYS=365
BFF_RETENTION_AUDIT_DAYS=365

# Local ID images (used in local mode)
ID_SERVICE_IMAGE=ghcr.io/updatingspace/id-service
ID_FRONTEND_IMAGE=ghcr.io/updatingspace/id-frontend
ID_IMAGE_TAG=latest

# Frontend
VITE_DEV_PROXY_TARGET=http://localhost:8080
VITE_BFF_BASE_URL=/api/v1
VITE_API_BASE_URL=/api/v1
VITE_ID_LOGIN_URL=http://id.localhost
VITE_TENANT_HINT=aef

# Activity/news media storage
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
# NEWS_MEDIA_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# YMQ outbox wake-up queues
# YMQ_ACTIVITY_QUEUE=https://message-queue.api.cloud.yandex.net/b1gxxxxxxxxxxxxxxx/activity-outbox
# YMQ_EVENTS_QUEUE=https://message-queue.api.cloud.yandex.net/b1gxxxxxxxxxxxxxxx/events-outbox
# YMQ_FEATUREFLAGS_QUEUE=https://message-queue.api.cloud.yandex.net/b1gxxxxxxxxxxxxxxx/featureflags-outbox
# YMQ_GAMIFICATION_QUEUE=https://message-queue.api.cloud.yandex.net/b1gxxxxxxxxxxxxxxx/gamification-outbox
# YMQ_VOTING_QUEUE=https://message-queue.api.cloud.yandex.net/b1gxxxxxxxxxxxxxxx/voting-outbox

# YC deploy metadata
# YC_API_GATEWAY_DOMAIN=*.updspace.com
# YC_CERTIFICATE_ID=fpqxxxxxxxxxxxxxxx
# YC_LOCKBOX_SECRET_RUNTIME_ID=e6qxxxxxxxxxxxxxxx
# YC_LOCKBOX_SECRET_RUNTIME_VERSION_ID=e6qxxxxxxxxxxxxxxx
